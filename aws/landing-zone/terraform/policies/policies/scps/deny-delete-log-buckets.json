{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteLogBuckets",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteBucket",
        "s3:DeleteBucketPolicy",
        "s3:PutBucketPolicy"
      ],
      "Resource": [
        "arn:aws:s3:::landing-zone-cloudtrail-*",
        "arn:aws:s3:::landing-zone-config-*",
        "arn:aws:s3:::landing-zone-vpc-flow-logs-*"
      ],
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": "arn:aws:iam::*:role/OrganizationAccountAccessRole"
        }
      }
    }
  ]
}
